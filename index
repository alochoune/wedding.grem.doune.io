<script>
  /* =========================================================
     CONFIGURATION
  ========================================================= */
  const ACCESS_CODE = "MOUSSE";   // <-- votre code d'invitation (nom de votre chat !)
  const WEDDING_DATE = "2028-05-28T15:00:00"; // Samedi 28 mai 2028, heure de cérémonie à ajuster si besoin
  const MAILTO_ADDRESS = "votre-adresse@example.com"; // <-- adresse recevant les RSVP

  /* Jour de la semaine et date calculés automatiquement à partir de WEDDING_DATE,
     pour que l'affichage reste toujours exact si vous ajustez l'heure. */
  const JOURS = ["Dimanche","Lundi","Mardi","Mercredi","Jeudi","Vendredi","Samedi"];
  const MOIS = ["janvier","février","mars","avril","mai","juin","juillet","août","septembre","octobre","novembre","décembre"];
  const heroDayEl = document.getElementById('heroDay');
  if(heroDayEl){
    const d = new Date(WEDDING_DATE);
    heroDayEl.textContent = `${JOURS[d.getDay()]} ${d.getDate()} ${MOIS[d.getMonth()]}`;
  }

  /* --- Gate --- */
  const gate = document.getElementById('gate');
  const site = document.getElementById('site');
  const input = document.getElementById('codeInput');
  const btn = document.getElementById('unlockBtn');
  const err = document.getElementById('gateError');

  function tryUnlock(){
    const val = input.value.trim().toUpperCase();
    if(val === ACCESS_CODE){
      sessionStorage.setItem('wedding_unlocked', '1');
      gate.style.display = 'none';
      site.classList.add('unlocked');
    } else {
      err.textContent = "Code invalide, merci de réessayer.";
    }
  }
  btn.addEventListener('click', tryUnlock);
  input.addEventListener('keydown', e => { if(e.key === 'Enter') tryUnlock(); });

  if(sessionStorage.getItem('wedding_unlocked') === '1'){
    gate.style.display = 'none';
    site.classList.add('unlocked');
  }

  /* --- Countdown --- */
  function updateCountdown(){
    const target = new Date(WEDDING_DATE).getTime();
    const now = new Date().getTime();
    const diff = target - now;
    const el = document.getElementById('countdown');
    if(diff <= 0){ el.innerHTML = '<div class="lab">C\'est aujourd\'hui !</div>'; return; }
    const d = Math.floor(diff/(1000*60*60*24));
    const h = Math.floor((diff/(1000*60*60))%24);
    const m = Math.floor((diff/(1000*60))%60);
    el.innerHTML = `
      <div><div class="num">${d}</div><div class="lab">Jours</div></div>
      <div><div class="num">${h}</div><div class="lab">Heures</div></div>
      <div><div class="num">${m}</div><div class="lab">Minutes</div></div>
    `;
  }
  updateCountdown();
  setInterval(updateCountdown, 60000);

  /* --- Galerie en fondu --- */
  const GALLERY_PHOTOS = [
    "photos/gallery/gallery-1.jpg","photos/gallery/gallery-2.jpg","photos/gallery/gallery-3.jpg",
    "photos/gallery/gallery-4.jpg","photos/gallery/gallery-5.jpg","photos/gallery/gallery-6.jpg",
    "photos/gallery/gallery-7.jpg","photos/gallery/gallery-8.jpg","photos/gallery/gallery-9.jpg",
    "photos/gallery/gallery-10.jpg","photos/gallery/gallery-11.jpg","photos/gallery/gallery-12.jpg",
    "photos/gallery/gallery-13.jpg","photos/gallery/gallery-14.jpg","photos/gallery/gallery-15.jpg",
    "photos/gallery/gallery-16.jpg","photos/gallery/gallery-17.jpg","photos/gallery/gallery-18.jpg",
    "photos/gallery/gallery-19.jpg","photos/gallery/gallery-20.jpg","photos/gallery/gallery-21.jpg",
    "photos/gallery/gallery-22.jpg","photos/gallery/gallery-23.jpg","photos/gallery/gallery-24.jpg",
    "photos/gallery/gallery-25.jpg","photos/gallery/gallery-26.jpg","photos/gallery/gallery-27.jpg",
    "photos/gallery/gallery-28.jpg","photos/gallery/gallery-29.jpg","photos/gallery/gallery-30.jpg",
    "photos/gallery/gallery-31.jpg","photos/gallery/gallery-32.jpg","photos/gallery/gallery-33.jpg",
    "photos/gallery/gallery-34.jpg","photos/gallery/gallery-35.jpg","photos/gallery/gallery-36.jpg",
    "photos/gallery/gallery-37.jpg","photos/gallery/gallery-38.jpg","photos/gallery/gallery-39.jpg",
    "photos/gallery/gallery-40.jpg","photos/gallery/gallery-41.jpg","photos/gallery/gallery-42.jpg",
    "photos/gallery/gallery-43.jpg","photos/gallery/gallery-44.jpg","photos/gallery/gallery-45.jpg",
    "photos/gallery/gallery-46.jpg","photos/gallery/gallery-47.jpg","photos/gallery/gallery-48.jpg",
    "photos/gallery/gallery-49.jpg","photos/gallery/gallery-50.jpg","photos/gallery/gallery-51.jpg",
    "photos/gallery/gallery-52.jpg","photos/gallery/gallery-53.jpg","photos/gallery/gallery-54.jpg",
    "photos/gallery/gallery-55.jpg","photos/gallery/gallery-56.jpg","photos/gallery/gallery-57.jpg",
    "photos/gallery/gallery-58.jpg","photos/gallery/gallery-59.jpg","photos/gallery/gallery-60.jpg",
    "photos/gallery/gallery-61.jpg","photos/gallery/gallery-62.jpg","photos/gallery/gallery-63.jpg",
    "photos/gallery/gallery-64.jpg","photos/gallery/gallery-65.jpg"
  ];
  (function initFadeGallery(){
    const cells = document.querySelectorAll('#fadeGallery .fade-cell');
    if(!cells.length) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const current = new Array(cells.length).fill(-1);

    function pickIndexFor(cellIdx){
      let idx, tries = 0;
      do {
        idx = Math.floor(Math.random() * GALLERY_PHOTOS.length);
        tries++;
      } while (current.includes(idx) && tries < 20);
      current[cellIdx] = idx;
      return idx;
    }

    cells.forEach((cell, i) => {
      const img = cell.querySelector('img');
      img.src = GALLERY_PHOTOS[pickIndexFor(i)];
      requestAnimationFrame(() => img.classList.add('visible'));
    });

    if(reduceMotion) return;

    function cycleOnce(){
      if(document.hidden) return;
      const cellIdx = Math.floor(Math.random() * cells.length);
      const img = cells[cellIdx].querySelector('img');
      img.classList.remove('visible');
      setTimeout(() => {
        img.src = GALLERY_PHOTOS[pickIndexFor(cellIdx)];
        requestAnimationFrame(() => img.classList.add('visible'));
      }, 1400);
    }
    setInterval(cycleOnce, 2600);
  })();

  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q').addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if(!isOpen) item.classList.add('open');
    });
  });

  /* --- RSVP form --> mailto --- */
  document.getElementById('rsvpForm').addEventListener('submit', function(e){
    e.preventDefault();
    const f = e.target;
    const subject = encodeURIComponent(`RSVP Mariage : ${f.name.value}`);
    const body = encodeURIComponent(
`Nom : ${f.name.value}
E-mail : ${f.email.value}
Présence : ${f.presence.value}
Nombre de personnes : ${f.guests.value}
Allergies / régime : ${f.allergies.value}
Message : ${f.message.value}`
    );
    window.location.href = `mailto:${MAILTO_ADDRESS}?subject=${subject}&body=${body}`;
  });
</script>

